      <!--Subsidiary-->
      <div class="">
        <div class="flex-1">
          <label for="id" class="text-sm font-medium text-base-content/80 text">Subsidiary</label>
          <%= form_tag current_team_path, method: :patch, class: "contents", local: true do %>
            <%= select_tag :id,                                    
                options_from_collection_for_select(Current.user.teams, :id, :name, Current.team&.id),
                class: "select mt-1 w-full font-semibold",
                onchange: "this.form.submit()" %>
          <% end %>
        </div>
      </div>

      <%= render "layouts/shared/theme_selector" %>
      <%= render "layouts/shared/user_block" %>

      <div class="">
        <%= button_to sign_out_path, method: :delete, class: "btn border-base-content/20 rounded-lg w-full flex items-center gap-2" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
          </svg>
          <span class="pb-0.5 text-base-content">Sign Out</span>
        <% end %>
      </div>
    </div>
  </div>
</aside>