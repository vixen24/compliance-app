<aside class="h-screen w-64 shrink-0 hidden xl:block bg-base-200 border-r border-base-200 overflow-y-auto min-h-0">
  <div class="h-full flex flex-col justify-between">
    <nav class="p-4">
      <div class="px-4 pt-1 pb-2 justify-self-center" style="text-align: -webkit-center;">
        <%= svg_tag "logo.svg", alt: "UBA Logo", class: "w-26" %>
      </div>
      <ul class="menu w-full p-0 text-base mt-2 hover:rounded-none">
        <li>
          <%= active_link_to team_dashboard_path, false, true, class:"active:bg-transparent p-2 rounded-sm active-link" do %>
          <svg xmlns="http://www.w3.org/2000/svg" height="22px" viewBox="0 -960 960 960" width="22px" fill="currentColor"><path d="M520-600v-240h320v240H520ZM120-440v-400h320v400H120Zm400 320v-400h320v400H520Zm-400 0v-240h320v240H120Zm80-400h160v-240H200v240Zm400 320h160v-240H600v240Zm0-480h160v-80H600v80ZM200-200h160v-80H200v80Zm160-320Zm240-160Zm0 240ZM360-280Z"/></svg>
          Dashboard
          <% end %>
        </li>
        <li>
          <%= active_link_to team_assessments_path, false, true, class:"active:bg-transparent p-2 rounded-sm active-link" do %>
          <svg xmlns="http://www.w3.org/2000/svg" height="22px" viewBox="0 -960 960 960" width="22px" fill="currentColor"><path d="M200-120q-33 0-56.5-23.5T120-200v-560q0-33 23.5-56.5T200-840h168q13-36 43.5-58t68.5-22q38 0 68.5 22t43.5 58h168q33 0 56.5 23.5T840-760v560q0 33-23.5 56.5T760-120H200Zm0-80h560v-560H200v560Zm80-80h280v-80H280v80Zm0-160h400v-80H280v80Zm0-160h400v-80H280v80Zm200-190q13 0 21.5-8.5T510-820q0-13-8.5-21.5T480-850q-13 0-21.5 8.5T450-820q0 13 8.5 21.5T480-790ZM200-200v-560 560Z"/></svg>
          Assessments
          <% end %>
        </li>
      </ul>
    </nav>
    
