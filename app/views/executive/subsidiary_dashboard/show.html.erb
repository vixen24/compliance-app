<% content_for(:title) { "Compliance at-a-Glance" } %>

<% content_for :left_sidebar do %>
  <%= render "executive/shared/left_sidebar" %>
<% end %>

<div class="flex flex-col p-8 h-screen">
  <header>
    <div class="flex gap-6">
      <!--Title-->
      <div class="pr-2 flex-2">
        <!--Back button -->
        <%= link_to "javascript:history.back()", class: "flex items-center gap-1 text-base font-semibold hover:bg-gray-200 w-fit rounded-lg py-1 px-3" do %>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2" class="w-4 h-4"><path d="M10 19l-7-7 7-7"/><path d="M3 12h18"/></svg>
          Back
        <% end %>
        <h2 class="text-4xl text-secondary font-black pt-2" style="font-family: 'Times New Roman', Times, serif">
          <% Current.user.role.capitalize %> Information Security Compliance at-a-Glance
        </h2>
        <p class="py-1">
          <div class="text-gray-600 text-xl" >Monitor compliance posture and approval flow. Use filters </div>
          <div class="text-gray-600 text-xl"> to spotlight risk, unblock approvals, and keep standards audit-ready</div>
        </p>
      </div>
      <div class="bg-primary-content py-4 px-5 rounded-2xl flex-1">
        <div class="text-xl text-white"><span class="font-bold"> <span class="bg-primary-content">&#127757;</span> UBA Group </span> has footprint across <span class=""> 24 countries</span></div>

        <!-- Team/Subsidiary -->
        <%= form_with url: executive_subsidiary_dashboard_path, method: :get, local: true, data: { controller: "autosave", action: "change->autosave#debouncedSubmit" } do |form| %>
          <div class="mt-2">
            <fieldset>
              <legend class="text-base text-neutral-100 mb-1.5">Select a country to view their compliance posture</legend>
              <%= form.select :team,
              Current.user.account.teams.order(:name).map { |t| [t.name, t.id] },
                { selected: @team&.id },
                {
                  class: "select w-full text-lg font-semibold"
                } %>
            </fieldset>
          </div>
        <% end %>
      </div>

      <!--Executive Insight-->
      <div class="bg-secondary py-4 px-5 rounded-2xl flex-1">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border bg-white border-white border-border/60 bg-card/40">
          <svg xmlns="http://www://w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="#FFC600" stroke="#FFC600" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-sparkles h-4 w-4 text-accent"> <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"></path> <path d="M20 3v4"></path> <path d="M22 5h-4"></path> <path d="M4 17v2"></path> <path d="M5 18H3"></path> </svg>
          <span class="text-xs font-bold text-foreground/90 text-secondary">Executive Insights</span>
        </div>
        <div class="mt-3 text-white">
          <ul class="space-y-2">
            <li class="flex items-start gap-2">
              <span class=" mt-0.5">◆</span><span><%= executive_insight(@compliance_percentage) %></span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </header>

  <!--Filters-->
  <%= form_with url: executive_subsidiary_dashboard_path, method: :get, local: true,
    data: { controller: "autosave", action: "change->autosave#debouncedSubmit" } do |form| %>
    <%= hidden_field_tag :team, @team&.id %>

    <div class="bg-white rounded-2xl px-8 pt-4 pb-6 mt-6 border border-gray-200 items-end shadow-md">
      <div>
        <span class="flex items-center gap-1 pb-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d51709" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"> <path d="M4 6h16M7 12h10M10 18h4"/> </svg>
          <span class="font-semibold"> FILTERS </span>
        </span>
      </div>
        
      <div class="grid grid-cols-[1fr_1fr_1fr] gap-8">
        <!-- Assessment Status -->
        <fieldset>
          <legend class="font-semibold mb-1 text-neutral-800">Assessment State</legend>
          <%= form.select :status,
            Assessment.statuses.keys.map { |k| [k.humanize, k] },
            { selected: @status },
            {
              class: "select w-full"
            } %>
        </fieldset>
        <!-- Assessment Name -->
        <fieldset>
          <legend class="font-semibold mb-1 text-neutral-800">Assessment Name</legend>
          <%= form.select :id,
            @assessments.map { |a| [a.name, a.id] },
            { selected: @assessment&.id || "" },
            {
              class: "select w-full"
            } %>
        </fieldset>
        <!-- Framework -->
        <fieldset>
          <legend class="font-semibold mb-1 text-neutral-800">Framework</legend>
          <%= form.select :framework,
            (@frameworks || []).map { |f| [f.code, f.id] },
            { include_blank: "All Frameworks", selected: @framework&.id },
            {
              class: "select w-full"
            } %>
        </fieldset>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 my-6">

    

    <!--Controls for framework in the current view-->
    <div class="p-5 pt-4 bg-white rounded-2xl shadow-md hover:shadow-lg transition-shadow duration-300 relative flex items-start gap-6">
      <div class=" inline-flex shrink-0 rounded-xl border border-neutral-200 bg-background/40 p-2.5 shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#d51709" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-git-branch h-5 w-5 text-foreground/80" aria-hidden="true" data-replit-metadata="client/src/pages/executive-dashboard.tsx:399:10" data-component-name="Icon"><line x1="6" x2="6" y1="3" y2="15"></line><circle cx="18" cy="6" r="3"></circle><circle cx="6" cy="18" r="3"></circle><path d="M18 9a9 9 0 0 1-9 9"></path></svg>
      </div>
      <div>
        <div class="flex items-center justify-between">
          <div class="text-sm font-semibold text-gray-500">
            CONTROLS
          </div>
        </div>
        <div class="font-bold text-4xl mt-2 text-gray-800" style="font-family: 'Times New Roman', Times, serif">
          <%= @total[:control_by_framework] %>
        </div>
        <div class="text-sm text-gray-500 mt-2">
          Controls for framework in the current view
        </div>
      </div>
    </div>

    <div>
      <!--Frameworks in the current view-->
      <div class="p-5 pt-4 bg-white rounded-2xl shadow-md hover:shadow-lg transition-shadow duration-300 relative flex items-start gap-6">
        <div class=" inline-flex shrink-0 rounded-xl border border-neutral-200 bg-background/40 p-2.5 shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#d51709" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-git-branch h-5 w-5 text-foreground/80" aria-hidden="true" data-replit-metadata="client/src/pages/executive-dashboard.tsx:399:10" data-component-name="Icon"><line x1="6" x2="6" y1="3" y2="15"></line><circle cx="18" cy="6" r="3"></circle><circle cx="6" cy="18" r="3"></circle><path d="M18 9a9 9 0 0 1-9 9"></path></svg>
        </div>
        <div>
          <div class="flex items-center justify-between">
            <div class="text-sm font-semibold text-gray-500">
              NOT APPLICABLE
            </div>
          </div>
          <div class="font-bold text-4xl mt-2 text-gray-800" style="font-family: 'Times New Roman', Times, serif">
            <%= @answer_status_count&.fetch("NA", 0) %>
          </div>
          <div class="text-sm text-gray-500 mt-2">
           Controls not in scope
          </div>
        </div>
      </div>
    </div>

    <!--Oldest response awaiting approval-->
    <div class="p-5 pt-4 bg-white rounded-2xl shadow-md hover:shadow-lg transition-shadow duration-300 relative flex items-start gap-6">
      <div class=" inline-flex shrink-0 rounded-xl border border-neutral-200 bg-background/40 p-2.5 shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#d51709" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-check h-5 w-5 text-primary" data-replit-metadata="client/src/pages/Dashboard.tsx:246:22" data-component-name="ShieldCheck"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path><path d="m9 12 2 2 4-4"></path></svg>
      </div>
      <div>
        <div class="flex items-center justify-between">
          <div class="text-sm font-semibold text-gray-500">
            LONGEST AWAITING APPROVAL
          </div>
        </div>
        <div class="font-bold text-4xl mt-2 text-gray-800" style="font-family: 'Times New Roman', Times, serif">
          <%= pluralize((Time.current.to_date - (@oldest_submitted_answer&.to_date || Time.current.to_date)).to_i, "day") %>

        </div>
        <div class="text-sm text-gray-500 mt-2">
          Oldest submission awaiting approval</span>
        </div>
      </div>
    </div>

    <!---Controls per assessement per framework-->
    <div class="p-5 pt-4 bg-white rounded-2xl shadow-md hover:shadow-lg transition-shadow duration-300 relative flex items-start gap-6">
      <div class=" inline-flex shrink-0 rounded-xl border border-neutral-200 bg-background/40 p-2.5 shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#d51709" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-check h-5 w-5 text-primary" data-replit-metadata="client/src/pages/Dashboard.tsx:246:22" data-component-name="ShieldCheck"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path><path d="m9 12 2 2 4-4"></path></svg>
      </div>
      <div>
        <div class="flex items-center justify-between">
          <div class="text-sm font-semibold text-gray-500">
            LATEST SUBMISSION
          </div>
        </div>
        <div class="font-bold text-4xl mt-2 text-gray-800" style="font-family: 'Times New Roman', Times, serif">
          <%= pluralize(((Time.current - (@earliest_submitted_answer || Time.current)) / 1.hour).to_i, "hour") %>
        </div>
        <div class="text-sm text-gray-500 mt-2">
          Most recent submission</span>
        </div>
      </div>
    </div>
  </div>

  <!---Charts -->
  <div class="flex justify-between flex-wrap gap-4">

    <!--Compliance chart-->
    <div class="flex self-start shadow-md transition-shadow px-4 py-1 rounded-2xl bg-white w-auto" style="">
      <div data-controller="compliance-chart" data-compliance-chart-values-value="<%= @status_values.to_json %>" 
          data-compliance-chart-labels-value="<%= @status_labels.to_json %>" class="">
      </div>

      <div class="legend pr-4 flex flex-col gap-2 place-content-center justify-center">

        <% colors = %w[green yellow red blue] %>

        <% @status_labels&.zip(@status_values, colors)&.each do |label, value, color| %>
          <!-- Legend with Linear Progress Bars -->
            <div class="legend-item">
              <div class="legend-header">
                <div class="label">
                  <span class="dot <%= color %>"></span> 
                  <%= label %>
                </div>

                <% width = number_to_percentage((value.to_f / @total[:control_by_framework]) * 100, precision: 0) || "0%" %>
                <span class="label__numbers"><%= value %> (<%= width %>)</span>
              </div>
              <div class="progress">
                <div class="progress-fill <%= color %>" style="width: <%= width %>"></div>
              </div>
            </div>
          <% end %>
      </div>
    </div>
    
    <!--Workflow chart-->
    <div class="flex self-center shadow-md transition-shadow px-4 py-1 rounded-2xl bg-white w-auto" style="">
      <div data-controller="workflow-chart" data-workflow-chart-values-value="<%= @state_values.to_json %>" 
          data-workflow-chart-labels-value="<%= @state_labels.to_json %>" class="">
      </div>

      <div class="legend pr-4 flex flex-col gap-2 place-content-center justify-center">

        <% colors = %w[green yellow red blue] %>

        <% @state_labels&.zip(@state_values, colors)&.each do |label, value, color| %>
          <!-- Legend with Linear Progress Bars -->
            <div class="legend-item">
              <div class="legend-header">
                <div class="label">
                  <span class="dot <%= color %>"></span> 
                  <%= label %>
                </div>

                <% width = number_to_percentage((value.to_f / @total[:control_by_framework]) * 100, precision: 0) || "0%" %>
                <span class="label__numbers"><%= value %> (<%= width %>)</span>
              </div>
              <div class="progress">
                <div class="progress-fill <%= color %>" style="width: <%= width %>"></div>
              </div>
            </div>
          <% end %>
      </div>
    </div> 
  </div>
</div>
