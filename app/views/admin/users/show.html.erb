<% content_for :title, "Show User" %>

<% content_for :left_sidebar do %>
  <%= render "admin/shared/left_sidebar" %>
<% end %>

<div class="h-screen overflow-y-auto">
  <header class="flex p-6 justify-between items-center">
    <div class="">
      <h2 class="text-3xl font-bold">
        User Account
      </h2>
      <p class="text-gray-600">View, edit and manage user account</p>
    </div>
  </header>
  <section class="mx-6">
    <!-- Name -->
    <div class="grid grid-cols-4 gap-16 w-max bg-white rounded-2xl p-8">
      <div class="text-xl"> Name : 
        <div class="font-semibold">
          <%= Current.user.name%>
        </div> 
      </div>
      <div class="text-xl"> Email address:
        <div class="font-semibold">
          <%= Current.user.email_address %>
        </div>
      </div>
      <div class="text-xl"> Team(s):
        <div class="font-semibold">
          <%= Current.user.teams.pluck(:name).to_sentence %>
        </div>
      </div>
      <div class="text-xl"> Role:
        <div class="font-semibold">
          <%= Current.user.role.capitalize %>
        </div>
      </div>
      <div class="text-xl"> Creation Time:
        <div class="font-semibold">
          <%= Current.user.created_at %>
        </div>
      </div>
      <div class="text-xl"> Active Session(s):
        <div class="font-semibold">
          <%= Current.user.sessions.count %>
        </div>
      </div>
      <div class="text-xl"> Last login:
        <div class="font-semibold">
           <% last_session = Current.user.sessions.order(created_at: :desc).first %>
          <%= last_session ? "#{time_ago_in_words(last_session.created_at)} ago" : "Never" %>
        </div>
      </div>
    </div>
  </section>
</div>