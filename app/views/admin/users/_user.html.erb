<tr id=<%= dom_id(user) %> class="odd:bg-gray-100 even:bg-white">
  <td class="p-2 pl-4 text-sm">
    <div class="flex items-center">
      <div class="shrink-0 h-9 w-9 bg-linear-to-br from-red-100 to-red-200 rounded-lg flex items-center justify-center">
        <span class="font-semibold text-red-700 tracking-wider">
          <%= user&.name&.split&.map(&:first)&.first(2)&.join&.upcase %>
        </span>
      </div>
      <div class="ml-4 min-w-0">
        <div class="leading-tight"><%= user&.name %></div>
        <div class="text-base-content/95 leading-tight"><%= user.email_address %></div>
      </div>
    </div>
  </td>
  <td class="p-2 text-sm whitespace-nowrap w-26">
    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full <%= user.active? ? 'bg-green-200 text-green-800' : 'bg-amber-200 text-amber-800' %>">
      <%= user.active? ? "Active" : "Inactive" %>
    </span>
  </td>
  <td class="p-2 text-sm overflow-ellipsis overflow-hidden">
    <%= user.teams.pluck(:name).to_sentence %>
  </td>
  <td class="p-2 text-sm whitespace-nowrap">
    <%= user.role.capitalize %>
  </td>
  <td class="p-2 text-sm overflow-ellipsis overflow-hidden">
    <%= user.created_at.strftime("%b %d, %Y %I:%M %p %Z") %>
  </td>
  <td class="p-2 text-sm overflow-ellipsis overflow-hidden">
    <%= user.updated_at.strftime("%b %d, %Y %I:%M %p %Z") %>
  </td>
  <td class="p-2 text-sm whitespace-nowrap">
    <div class="flex flex-wrap items-center">
      <% unless user.owner? %>
        <div data-controller="dialog" data-dialog-modal-value="true" data-action="keydown.esc->dialog#close:stop">
          <button type="button" data-action="dialog#open"
            class="inline-flex items-center gap-1 px-2 py-1.5 text-sm text-blue-600 hover:text-blue-900 hover:bg-blue-100 rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"> <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path> </svg>
            <span>Edit</span>
          </button>
          <dialog class="m-auto dialog-panel" style="--panel-size: 48ch" data-dialog-target="dialog" role="dialog" aria-modal="true">
            <%= turbo_frame_tag "edit-user", src: edit_admin_user_path(user, password_reset: false), loading:"lazy" %>
          </dialog>
        </div>
        <div data-controller="dialog" data-dialog-modal-value="true" data-action="keydown.esc->dialog#close:stop">
          <button type="button" data-action="dialog#open"
            class="inline-flex items-center justify-center gap-1 px-2 py-1.5 text-sm text-blue-600 hover:text-blue-900 hover:bg-blue-100 rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"> <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path> </svg>
            <span>Reset Password</span>
          </button>
          <dialog class="m-auto dialog-panel" style="--panel-size: 48ch" data-dialog-target="dialog" role="dialog" aria-modal="true">
            <%= turbo_frame_tag "edit-user", src: edit_admin_user_path(user, password_reset: true), loading:"lazy" %>
          </dialog>
        </div>
        <%= link_to admin_user_path(user, toggle: true), data: { turbo_method: :patch },
          class: "w-26 inline-flex items-center gap-1 px-2 py-1.5 text-sm #{user.active? ? 'text-amber-600 hover:text-amber-900 hover:bg-amber-100' : 'text-emerald-600 hover:text-emerald-900 hover:bg-emerald-100'} rounded-lg transition-colors" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path> </svg>
          <%= user.active? ? "Deactivate" : "Activate" %>
        <% end %>
        <%= button_to admin_user_path(user), 
            method: :delete, data: { turbo_confirm: "Are you sure you want to delete #{user&.name}?" },
            class: "inline-flex items-center gap-1 px-2 py-1.5 text-sm text-red-600 hover:text-red-900 hover:bg-red-100 rounded-lg transition-colors" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
          </svg>
          Delete
        <% end %>
      <% end %>
    </div>
  </td>
</tr>