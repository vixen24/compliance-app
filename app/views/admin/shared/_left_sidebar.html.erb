      <!--Avatar and name-->
      <div class="flex flex-row gap-3 items-center mx-4 py-2 px-3 rounded-lg bg-neutral-700">
        <div class="shrink-0 h-9 w-9 bg-linear-to-br from-red-200 to-red-300 rounded-lg flex items-center justify-center">
          <span class="font-semibold text-red-700 text-sm">
            <%= Current.user&.name&.split&.map(&:first)&.first(2)&.join&.upcase %>
          </span>
        </div>
        <div class="overflow-hidden">
          <div class="text-sm font-semibold text-white truncate"><%= Current.user.name || Current.user.email_address %></div>
          <div class="text-sm text-white"><%= Current.user.role.capitalize %></div>
        </div>
      </div>

      <div class="p-4">
        <%= button_to sign_out_path, method: :delete, class: "btn rounded-lg w-full bg-base-200 flex items-center gap-2" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
          </svg>
          <span class="pb-0.5">Sign Out</span>
        <% end %>
