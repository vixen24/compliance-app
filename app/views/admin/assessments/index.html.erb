<% content_for :title, "Assessments" %>

<% content_for :left_sidebar do %>
  <%= render "admin/shared/left_sidebar" %>
<% end %>

<%= turbo_stream_from "assessments_#{Current.user.account.id}" %>

<div class="h-screen flex flex-col overflow-hidden">
  
  <header class="p-4 sm:p-4 lg:p-6 pb-0">
    <div class="bg-white flex items-center justify-between gap-4 p-4 rounded-lg">
      <div>
        <h1 class="text-2xl font-bold text-secondary">
          Assessments
        </h1>
        <p class="mt-1 text-sm text-gray-600">
          Create and manage assessment lifecycle across subsidiaries
        </p>
      </div>
      <%= link_to new_admin_assessment_path, class: "btn border-none bg-primary-content focus:bg-primary rounded-lg text-gray-100 flex items-center gap-2" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"> <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /> </svg>
        <span class="hidden sm:inline"> Create Assessment </span>
        <span class="sr-only sm:hidden"> Create Assessment </span>
      <% end %>
    </div>
  </header>
  
  <section id="assessments_list" class="grid grid-cols-1 sm:grid-cols-4 md:grid-cols-4 lg:grid-cols-4 gap-4 overflow-y-auto p-6 pt-0">
    <%= render @assessments %>
  </section>
</div>