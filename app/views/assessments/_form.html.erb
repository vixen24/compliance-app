<%= form_with model: @assessment, url: team_assessments_path do |form| %>
    <div class="flex flex-col gap-y-8 px-8">
`    <div class="w-full mt-1">
      <%= form.text_field :name, required: true, autofocus: true, value: params[:name], placeholder: "Name of assessment",
          class: "text-2xl block font-semibold border-b-2 focus:border-secondary border-gray-200 focus:outline-none px-2 py-1 w-full " %>
    </div>
      
    <fieldset class="">
      <legend class="font-semibold mb-2 text-gray-600">
        Security framework(s)
      </legend>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-2">
        <% Framework.all.each do |framework| %>
          <label class="flex items-center gap-2 mb-1 cursor-pointer">
            <%= form.check_box :framework_ids, { multiple: true, class: "checkbox checkbox-sm" }, framework.id, nil %>
            <p><%= framework.code %></p>
          </label>
        <% end %>
      </div>
    </fieldset>

    <fieldset class="w-full -mt-2">
      <legend class="font-semibold mb-2 text-gray-600">
        Due date
      </legend>
      <%= form.date_field :due_date, value: params[:due_date],
          class: "input input-border w-full" %>
      <p class="text-xs text-gray-500 pt-1">Optional</p>
    </fieldset>`
  </div>

  <div class="p-8 flex justify-end">
    <%= form.submit "Save", class: "btn rounded-lg bg-primary-content text-base text-gray-100 focus:bg-primary" %>
  </div>
<% end %>
