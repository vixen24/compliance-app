<div class="mx-auto  text-center p-64">
  <div class="justify-items-center p-12 pt-0" style="text-align: -webkit-center">
    <%= svg_tag "logo.svg", alt: "UBA Logo", class: "w-36" %>
  </div>
  <h1 class="font-semibold mb-2 text-3xl">
    Your access is pending
  </h1>

  <p class="text-gray-600 text-center text-xl pt-4 pb-1">This profile is not assigned to a Team.</p>
  <p class="text-gray-600 mb-12 text-center text-xl">Please contact the administrator.</p> 

  <%= button_to "Sign Out", sign_out_path, method: :delete, class: "btn rounded-lg bg-primary text-white text-base" %>
</div>
