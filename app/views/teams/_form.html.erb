<%= form_with model: @team, class: "contents" do |form| %>
  <%= form.hidden_field :account_id, value: Current.user.account.id %>

    <div class="flex flex-col gap-y-3 px-8 w-full">
      <div>
        <%= form.label :name, class:"text-sm font-medium text-base-content/80" %>
        <%= form.text_field :name, autocomplete: "off", class: "input w-full #{'border-red-500' if @team.errors[:name].any?}" %>
        <%= field_error(@team, :name) %>
      </div>

      <div class="">
        <%= form.label :user_ids, "Users", class: "text-sm font-medium text-base-content/80" %>
        <%= select_tag "team[user_ids][]", options_from_collection_for_select(@users, :id, :email_address, @team.user_ids),
            multiple: true,
            data: {
              controller: "tom-select",
              tom_select_placeholder_value: "Click to add..."
            },
            class: "w-full" %>
        <%= field_error(@team, :user) %>
      </div>
    </div>

    <div class="px-8 py-6 flex gap-4 justify-end">
      <%= link_to "Cancel", teams_path, data:{turbo: false}, class: "btn rounded-lg bg-white border border-neutral-800 text-neutral-800" %>
      <%= form.submit(@team.persisted? ? "Update Team" : "Create Team", class: "btn rounded-lg bg-primary-content text-base text-gray-100 focus:bg-primary border-none") %>
    </div>
  <% end %>
